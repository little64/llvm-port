# RUN: llc -mtriple=little64 -run-pass=branch-relaxation -o - %s | FileCheck %s

--- |
  define void @relax_long_jmp() {
  entry:
    br label %exit
  pad:
    br label %exit
  exit:
    ret void
  }
...
