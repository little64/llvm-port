# RUN: llc -mtriple=little64 -run-pass=branch-relaxation -o - %s | FileCheck %s

--- |
  define void @relax_long_cond() {
  entry:
    br i1 true, label %target, label %exit
  pad:
    br label %exit
  target:
    ret void
  exit:
    ret void
  }
...
---
name:            relax_long_cond
tracksRegLiveness: true
body:             |
  bb.0.entry:
    liveins: $flags
    JUMP_Z %bb.2, implicit $r15, implicit $flags
    JMP %bb.1

  bb.1.pad:
    $r1 = LDI 0
    $r1 = LDI 0
