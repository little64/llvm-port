# RUN: llc -mtriple=little64 -run-pass=little64-expand-pseudos -o - %s | FileCheck %s

--- |
  target triple = "little64"

  declare i64 @ext_target(i64)

  define i64 @expand_ldi64_cases(i64 %x) {
  entry:
    ret i64 %x
  }
...
---
name:            expand_ldi64_cases
alignment:       2
tracksRegLiveness: true
registers:
  - { id: 0, class: gpr, preferred-register: '', flags: [  ] }
  - { id: 1, class: gpr, preferred-register: '', flags: [  ] }
  - { id: 2, class: gpr, preferred-register: '', flags: [  ] }
  - { id: 3, class: gpr, preferred-register: '', flags: [  ] }
liveins:
  - { reg: '$r10', virtual-reg: '%0' }
machineFunctionInfo: {}
body:             |
  bb.0.entry:
    liveins: $r10

    %0:gpr = COPY $r10
    %1:gpr = LDI64 305419896
    %2:gpr = LDI64 -1
    %3:gpr = LDI64 @ext_target
    $r1 = COPY %1
    RET $r1, implicit $r14

...

# CHECK-LABEL: name:            expand_ldi64_cases
# CHECK: %1:gpr = LDI 120
# CHECK: %1:gpr = LDI_S1 86, %1
# CHECK: %1:gpr = LDI_S2 52, %1
# CHECK: %1:gpr = LDI_S3 18, %1
# CHECK: %2:gpr = LDI 255
# CHECK: %2:gpr = LDI_S1 255, %2
# CHECK: %2:gpr = LDI_S2 255, %2
# CHECK: %2:gpr = LDI_S3 255, %2
# CHECK: JMP 4
# CHECK: LDI64_RELOC_DATA @ext_target
# CHECK: %3:gpr = LOAD_PCREL -5
# CHECK-NOT: LDI64
